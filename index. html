    <!-- SCRIPT DE RASTREO INTELIGENTE UNIFICADO -->
    <script>
      document.addEventListener("click", function(e) {
        let link = e.target.closest("a");
        if (!link) return;

        // CASILLA OFICIAL DE AMAZON
        if (link.href.includes("amazon.com")) {
          let url = new URL(link.href);
          url.searchParams.set("tag", "jenzblaster-20");
          link.href = url.toString();
        }

        // CASILLA OFICIAL DE EBAY
        if (link.href.includes("ebay.com")) {
          let url = new URL(link.href);
          url.searchParams.set("campid", "TU_ID_DE_EBAY"); 
          link.href = url.toString();
        }
      });
    </script>

    <style>
        /* DISEÑO RESPONSIVO CORREGIDO: TARJETAS A LA MITAD Y SIN SOBREPOSICIÓN */
