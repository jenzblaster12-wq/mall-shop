        .producto p { font-size: 11px; color: #555; line-height: 1.3; margin: 5px 0; text-align: center; }
        
        /* Botones optimizados */
        .btn-enlace { display: block; width: 100%; text-align: center; padding: 7px 0; margin: 4px 0; border: none; border-radius: 4px; cursor: pointer; text-decoration: none; font-weight: bold; font-size: 11px; box-sizing: border-box; }
        .btn-principal { background-color: #0073e6; color: rgb(20, 23, 2); }
        .btn-chat { background-color: #25d366; color: rgb(26, 40, 1); }
        
        .contenedor-publicidad { display: flex; flex-wrap: wrap; gap: 15px; margin-top: 25px; justify-content: center; }
        .cuadro-publicidad { background: #96bbe8; border: 1px dashed #333; padding: 12px; width: 45%; min-width: 250px; text-align: center; border-radius: 6px; font-size: 13px; }
        .btn-anunciate { display: inline-block; background: #333; color: #fff; padding: 6px 12px; border-radius: 4px; margin-top: 8px; cursor: pointer; font-size: 11px; text-decoration: none; }
        .seccion-descargo { background: #333; color: #fff; text-align: center; padding: 15px; margin-top: 35px; font-size: 11px; line-height: 1.4; }
        .whatsapp-flotante { position: fixed; bottom: 20px; right: 20px; background: #25d366; color: white; border-radius: 50%; width: 50px; height: 50px; display: flex; align-items: center; justify-content: center; font-size: 24px; text-decoration: none; box-shadow: 0 3px 8px rgba(0,0,0,0.3); z-index: 1000; }
    </style>
